# 复制为 .env 后填入实际值

# ===== 企业微信 =====
# 企业 ID: 企微管理后台 → 我的企业 → 企业信息
WXWORK_CORPID=wwxxxxxxxxxxxxxxxx
# 自建应用 AgentId: 应用管理 → 自建应用详情
WXWORK_AGENTID=1000000
# 自建应用 Secret: 应用管理 → 自建应用 → Secret
WXWORK_APP_SECRET=__FILL_HERE__
# 会话存档 Secret: 客户与上下游 → 客户联系 → 会话存档 → 添加密钥
WXWORK_ARCHIVE_SECRET=__FILL_HERE__
# RSA 私钥路径(配合会话存档加密) - 自己生成 + 公钥配到企微后台
WXWORK_PRIVATE_KEY_PATH=/app/secrets/private_key.pem

# ===== 服务 =====
APP_PORT=8098
DOMAIN=your-domain.com
# JWT 加密密钥(生成: openssl rand -hex 32)
JWT_SECRET=__FILL_HERE__
JWT_TTL_SECONDS=28800

# ===== 首个超管账号(只在 admins 表为空时 seed 一次) =====
# 创建完后清掉这两行,免得密码留在 .env 里
# 也可以不配,启动后跑 `docker exec kefu-backend python admin_init.py <user> <pass>`
ADMIN_INIT_USERNAME=
ADMIN_INIT_PASSWORD=

# ===== 会话存档拉取 =====
DB_PATH=/app/data/chat.db
PULL_INTERVAL_SECONDS=3
SDK_LIB_PATH=/app/lib/libWeWorkFinanceSdk_C.so

# ===== 阿里百炼 (RAG embedding) =====
# 用 text-embedding-v4 (Qwen3-Embedding 商用版)
ALIYUN_API_KEY=__FILL_HERE__
ALIYUN_EMBED_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
ALIYUN_EMBED_MODEL=text-embedding-v4
ALIYUN_EMBED_DIM=1024

# ===== DeepSeek (AI 草稿生成,主选) =====
DEEPSEEK_API_KEY=__FILL_HERE__
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-v4-flash

# ===== 豆包 / 火山方舟 (AI 草稿生成,备选) =====
DOUBAO_API_KEY=__FILL_HERE__
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# ===== LanceDB (已弃用,代码里仍读取所以留着,任意路径) =====
LANCEDB_PATH=/app/data/lancedb
